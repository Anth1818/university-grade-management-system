---
import LayoutSideBar from "@/layouts/LayoutSideBar.astro";
import StudentTableGrades from "@/components/students/TableGrades.astro";
import { DownloadGradesButton } from "@/components/students/DownloadGradesButton";
import { ButtonNavigate } from "@/components/shared/ButtonNavigate";
---

<LayoutSideBar>
  <div class="container mx-auto p-4">
    <StudentTableGrades>
      <DownloadGradesButton slot="download-button" client:load />
      <div slot="recovery-button" class="flex justify-center">
        <ButtonNavigate url="/students/recoverySubject" className="mt-2" client:load>
          Ver recuperación
        </ButtonNavigate>
      </div>
    </StudentTableGrades>
  </div>
</LayoutSideBar>
