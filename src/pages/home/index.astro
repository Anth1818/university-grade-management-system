---
import LayoutSideBar from "@/layouts/LayoutSideBar.astro";
const user = "Pepe"

---

<LayoutSideBar>
 <h1 class="text-2xl font-bold text-center">Bienvenido al sistema de notas UAR</h1>
 <p class="text-center">Usuario: {user}</p>
 <div class="flex justify-center gap-4 flex-col">
   <p class="text-center">Navega por las opciones del menu lateral para acceder a las funcionalidades del sistema</p>
   <p class="text-red-500 font-bold text-center text-lg">Atencion: El sistema esta en desarrollo, por favor reporta cualquier error que encuentres</p>
 </div>
</LayoutSideBar>
