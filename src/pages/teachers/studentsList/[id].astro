---
import LayoutSideBar from "@/layouts/LayoutSideBar.astro";
import { sectionListData } from '@/data/sectionsListData';
import StudentListContainer from '@/components/teachers/studentsList/StudentListContainer';

const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/teachers/sections');
}

// Obtener los estudiantes de la sección actual
const section = sectionListData.find(sec => sec.idSection === id);
const students = section?.students || [];

// Configuración de paginación
const itemsPerPage = 5;
---

<LayoutSideBar>
  <StudentListContainer students={students} itemsPerPage={itemsPerPage} idSection={id} client:load/>
</LayoutSideBar>
