---
import CertificateFormat from "@/components/shared/CertificateFormat.astro";
import StudyCertificateContent from "./StudyCertificateContent.astro";

const studentName = "Anthony Ruiz";
const studentId = "123456789";
const career = "Ingeniería en Informática";
const date = new Date().toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<CertificateFormat certificateTitle="Constancia de estudio">
    <StudyCertificateContent studentName={studentName} studentId={studentId} career={career} date={date} />
</CertificateFormat>

