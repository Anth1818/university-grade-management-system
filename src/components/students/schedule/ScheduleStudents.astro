---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { semesterSubjectsData } from "@/data/semesterSubjectsData";
import { recoverySubjectsData } from "@/data/recoverySubjectsData";
import type { Subject } from "@/lib/types";
import { cn } from "@/lib/utils";

interface Props {
  className?: string;
  studentNeedRecovery: boolean;
  schedule: any[];
  semesterName?: string;
}

const { className, studentNeedRecovery, schedule, semesterName = "Actual" } = Astro.props;
---

<Card className={cn("w-full", className)}>
  <CardHeader className="flex flex-row items-center justify-between pb-2">
    <div>
      <CardTitle>Horario de Clases</CardTitle>
      <CardDescription>
        {
          studentNeedRecovery
            ? "Detalles de tu horario de recuperación"
            : "Detalles de tu horario para el semestre actual."
        }
      </CardDescription>
    </div>
    <div class="flex items-center">
      <slot name="download-button" />
    </div>
  </CardHeader>
  <CardContent className="space-y-6">
    {
      !studentNeedRecovery ? (
        <div>
          <h3 class="text-lg font-semibold mb-2">
            Horario Semestral - {semesterName}
          </h3>
          <div class="rounded-md border">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Materia</TableHead>
                  <TableHead>Profesor</TableHead>
                  <TableHead>Día</TableHead>
                  <TableHead>Hora</TableHead>
                  <TableHead>Aula</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {schedule?.map((subject) => (
                  <TableRow>
                    <TableCell className="font-medium">
                      {subject.name}
                    </TableCell>
                    <TableCell>{subject.teacher}</TableCell>
                    <TableCell>{subject.day}</TableCell>
                    <TableCell>{subject.time}</TableCell>
                    <TableCell>{subject.classroom}</TableCell>
                  </TableRow>
                ))}
                {schedule?.length === 0 && (
                  <TableRow>
                    <TableCell colspan="5" className="text-center py-4 text-muted-foreground">
                      No tienes materias inscritas para este período.
                    </TableCell>
                  </TableRow>
                )}
              </TableBody>
            </Table>
          </div>
        </div>
      ) : (
        <div>
          <h3 class="text-lg font-semibold mb-2 text-amber-700">
            Horario de Recuperación
          </h3>
          <div class="rounded-md border border-amber-200">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Materia</TableHead>
                  <TableHead>Profesor</TableHead>
                  <TableHead>Día</TableHead>
                  <TableHead>Hora</TableHead>
                  <TableHead>Aula</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {schedule?.map((subject) => (
                  <TableRow>
                    <TableCell className="font-medium">
                      {subject.name}
                    </TableCell>
                    <TableCell>{subject.teacher}</TableCell>
                    <TableCell>{subject.day}</TableCell>
                    <TableCell>{subject.time}</TableCell>
                    <TableCell>{subject.classroom}</TableCell>
                  </TableRow>
                ))}
                {schedule?.length === 0 && (
                  <TableRow>
                    <TableCell colspan="5" className="text-center py-4 text-amber-700 font-medium">
                      No tienes materias inscritas en recuperación.
                    </TableCell>
                  </TableRow>
                )}
              </TableBody>
            </Table>
          </div>
        </div>
      )
    }
  </CardContent>
</Card>
