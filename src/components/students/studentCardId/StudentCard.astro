---
import { Card, CardContent } from "@/components/ui/card";
import { QrCode } from "lucide-react";
import logo from "@/assets/uar-logo.png";
import avatarSvg from "@/assets/avatar.svg";

interface Props {
  name: string;
  lastName: string;
  studentId: string;
  program: string;
  campus: string;
  universityName: string;
  photoUrl?: string;
}

const {
  name,
  lastName,
  studentId,
  program,
  campus,
  universityName,
  photoUrl,
} = Astro.props;
---

<Card id="student-card" className="w-72 h-auto bg-background text-foreground border-2 border-primary/80 rounded-lg overflow-hidden flex flex-col shadow-lg">
  <!-- University Header -->
  <div class="bg-primary text-primary-foreground py-2 px-3 text-center">
    <h2 class="font-bold text-sm">{universityName}</h2>
  </div>

  <CardContent className="flex-1 p-4 flex flex-col items-center justify-between gap-4">
    <!-- Photo and Basic Info -->
    <div class="flex flex-col items-center space-y-3 w-full">
      <div class="w-20 h-20 rounded-full border-2 border-primary overflow-hidden bg-background flex items-center justify-center shadow-sm">
        {photoUrl ? (
          <img src={photoUrl} alt={`${name} ${lastName}`} class="w-full h-full object-cover" />
        ) : (
          <img src={avatarSvg.src} alt={`Avatar de ${name} ${lastName}`} class="w-full h-full object-contain p-1 dark:bg-gray-800 dark:text-white" />
        )}
      </div>

      <div class="text-center space-y-0.5">
        <h3 class="text-lg font-bold text-foreground">{name} {lastName}</h3>
        <p class="text-xs text-muted-foreground font-medium">ID: {studentId}</p>
      </div>
    </div>

    <!-- Program and Campus -->
    <div class="w-full space-y-2.5 px-2">
      <div class="border-b border-primary/30 pb-2">
        <p class="text-xs text-muted-foreground font-medium">Carrera</p>
        <p class="text-sm font-semibold text-foreground">{program}</p>
      </div>
      <div>
        <p class="text-xs text-muted-foreground font-medium">Campus</p>
        <p class="text-sm font-semibold text-foreground">{campus}</p>
      </div>
    </div>

    <!-- QR Code -->
    <div class="w-20 h-20 bg-background border border-primary/30 rounded flex items-center justify-center mt-1 shadow-sm">
      <QrCode className="w-14 h-14 text-primary" />
    </div>

    <!-- University Logo -->
    <img src={logo.src} alt="Logo" class="w-15 m-auto rounded-xl" />
  </CardContent>
</Card>

<style is:global>
  @page {
      size: auto;
      margin: 0;
  }
  @media print {
      body {
          background: white !important;
      }
      body * {
          visibility: hidden;
      }
      #student-card, #student-card * {
          visibility: visible;
      }
      #student-card {
          position: absolute;
          top: 40%;
          left: 50%;
          transform: translate(-50%, -50%);
          box-shadow: none !important;
          margin: 0 !important;
      }

      #print-button-student-card {
          display: none;
      }
      
  }
</style>
  