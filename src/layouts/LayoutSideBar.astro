---
import "../styles/global.css";
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/layout/sidebar";

const { title = "UAR | App" } = Astro.props;
const { user } = Astro.locals;

---

<Layout title={title}>
  <Sidebar client:load user={user}>
    <slot />
  </Sidebar>
</Layout>